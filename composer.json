{
    "name": "lingodotdev/sdk",
    "description": "Official PHP SDK for Lingo.dev",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Lingo.dev Team",
            "email": "hi@lingo.dev"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0",
        "respect/validation": "^2.0",
        "phpdocumentor/shim": "^3.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "saggre/phpdocumentor-markdown": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "LingoDotDev\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LingoDotDev\\Sdk\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "phpdocumentor/shim": true
        }
    }
}
